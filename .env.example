# LLM provider: "ollama" (local, default) or "groq" (cloud)
LLM_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Groq (only needed if LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional self-hosted SearxNG instance; falls back to DuckDuckGo scraping if empty
SEARXNG_URL=

# Agent loop limits
MAX_TOOL_ITERATIONS=6
MAX_HANDOFFS=4

# Set to false ONLY behind a corporate TLS-intercepting proxy (self-signed cert).
# Disables outbound certificate verification. Leave true in normal environments.
SSL_VERIFY=true
